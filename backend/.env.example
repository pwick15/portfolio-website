RECAPTCHA_SITE_KEY=6LdZQxItAAAAAKMVpimaDUZESK3_SEO8u-XmZB7I

# Private key used on the backend server (KEEP SECURE)
RECAPTCHA_SECRET_KEY=YOUR_RECAPTCHA_SECRET_KEY_HERE
